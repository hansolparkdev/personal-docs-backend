# App
APP_ENV=development
SECRET_KEY=change-me

# PostgreSQL + pgvector
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/personal_docs

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=personal-docs
MINIO_SECURE=false

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=personal-docs
KEYCLOAK_CLIENT_ID=backend
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_JWKS_CACHE_TTL=600
KEYCLOAK_ADMIN_CLIENT_ID=backend

# LLM (OpenAI or compatible)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
